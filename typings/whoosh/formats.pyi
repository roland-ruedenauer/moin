class Format:
    posting_size: int
    textual: bool
    __inittypes__: Incomplete
    field_boost: Incomplete
    options: Incomplete
    def __init__(self, field_boost: float = 1.0, **options) -> None: ...
    def __eq__(self, other): ...
    def fixed_value_size(self): ...
    def word_values(self, value, analyzer, **kwargs) -> None: ...
    def supports(self, name): ...
    def decoder(self, name): ...
    def decode_as(self, astype, valuestring): ...

def tokens(value, analyzer, kwargs): ...

class Existence(Format):
    posting_size: int
    __inittypes__: Incomplete
    field_boost: Incomplete
    options: Incomplete
    def __init__(self, field_boost: float = 1.0, **options) -> None: ...
    def word_values(self, value, analyzer, **kwargs): ...
    def encode(self, value): ...
    def decode_frequency(self, valuestring): ...
    def decode_weight(self, valuestring): ...
    def combine(self, vs): ...

class Frequency(Format):
    posting_size: Incomplete
    __inittypes__: Incomplete
    field_boost: Incomplete
    options: Incomplete
    def __init__(self, field_boost: float = 1.0, boost_as_freq: bool = False, **options) -> None: ...
    def word_values(self, value, analyzer, **kwargs): ...
    def decode_frequency(self, valuestring): ...
    def decode_weight(self, valuestring): ...
    def combine(self, vs): ...

class Positions(Format):
    def word_values(self, value, analyzer, **kwargs) -> Generator[Incomplete]: ...
