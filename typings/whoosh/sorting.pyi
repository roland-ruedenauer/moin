from _typeshed import Incomplete
from collections.abc import Generator
from whoosh.compat import iteritems as iteritems, izip as izip, string_type as string_type, xrange as xrange

class FacetType:
    maptype: Incomplete
    def categorizer(self, global_searcher) -> None: ...
    def map(self, default=None): ...
    def default_name(self): ...

class Categorizer:
    allow_overlap: bool
    needs_current: bool
    def set_searcher(self, segment_searcher, docoffset) -> None: ...
    def key_for(self, matcher, segment_docnum): ...
    def keys_for(self, matcher, segment_docnum): ...
    def key_to_name(self, key): ...

class FieldFacet(FacetType):
    fieldname: Incomplete
    reverse: Incomplete
    allow_overlap: Incomplete
    maptype: Incomplete
    def __init__(self, fieldname, reverse: bool = False, allow_overlap: bool = False, maptype=None) -> None: ...
    def default_name(self): ...
    def categorizer(self, global_searcher): ...

class ColumnCategorizer(Categorizer):
    def __init__(self, global_searcher, fieldname, reverse: bool = False) -> None: ...
    def set_searcher(self, segment_searcher, docoffset) -> None: ...
    def key_for(self, matcher, segment_docnum): ...
    def key_to_name(self, key): ...

class ReversedColumnCategorizer(ColumnCategorizer):
    def __init__(self, global_searcher, fieldname) -> None: ...
    def key_for(self, matcher, segment_docnum): ...
    def key_to_name(self, key): ...

class OverlappingCategorizer(Categorizer):
