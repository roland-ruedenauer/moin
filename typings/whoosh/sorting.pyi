    def __init__(self, items=None, maptype=None) -> None: ...
    @classmethod
    def from_sortedby(cls, sortedby): ...
    def add_field(self, fieldname, reverse: bool = False): ...
    def add_query(self, querydict, other=None, allow_overlap: bool = False): ...
    def add_score(self): ...
    def add_facet(self, facet): ...
    def categorizer(self, global_searcher): ...

    class MultiCategorizer(Categorizer):
        catters: Incomplete
        def __init__(self, catters) -> None: ...
        @property
        def needs_current(self): ...
        def set_searcher(self, segment_searcher, docoffset) -> None: ...
        def key_for(self, matcher, docid): ...
