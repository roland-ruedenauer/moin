class IndexingError(Exception): ...

@contextmanager
def groupmanager(writer) -> Generator[None]: ...
def NO_MERGE(writer, segments): ...
def MERGE_SMALL(writer, segments): ...
def OPTIMIZE(writer, segments): ...
def CLEAR(writer, segments): ...

class PostingPool(SortingPool):
    namechars: str
    tempstore: Incomplete
    segment: Incomplete
    limit: Incomplete
    currentsize: int
    fieldnames: Incomplete
    def __init__(self, tempstore, segment, limitmb: int = 128, **kwargs) -> None: ...
    def add(self, item) -> None: ...
    def iter_postings(self): ...
    def save(self) -> None: ...

class IndexWriter:
    def __enter__(self): ...
    def __exit__(
        self, exc_type: type[BaseException] | None, exc_val: BaseException | None, exc_tb: types.TracebackType | None
    ) -> None: ...
    def group(self): ...
    def start_group(self) -> None: ...
    def end_group(self) -> None: ...
    def add_field(self, fieldname, fieldtype, **kwargs) -> None: ...
    def remove_field(self, fieldname, **kwargs) -> None: ...
    @abstractmethod
    def reader(self, **kwargs) -> None: ...
    def searcher(self, **kwargs): ...
    def delete_by_term(self, fieldname, text, searcher=None): ...
    def delete_by_query(self, q, searcher=None): ...
    @abstractmethod
    def delete_document(self, docnum, delete: bool = True) -> None: ...
    @abstractmethod
    def add_document(self, **fields) -> None: ...
    @abstractmethod
    def add_reader(self, reader) -> None: ...
    def update_document(self, **fields) -> None: ...
    def commit(self) -> None: ...
    def cancel(self) -> None: ...

class SegmentWriter(IndexWriter):
    writelock: Incomplete
    codec: Incomplete
    storage: Incomplete
    indexname: Incomplete
    generation: Incomplete
    schema: Incomplete
    segments: Incomplete
    docnum: Incomplete
    newsegment: Incomplete
    compound: Incomplete
    is_closed: bool
    pool: Incomplete
    perdocwriter: Incomplete
    fieldwriter: Incomplete
    merge: bool
    optimize: bool
    mergetype: Incomplete
    def __init__(
        self,
        ix,
        poolclass=None,
        timeout: float = 0.0,
        delay: float = 0.1,
        _lk: bool = True,
        limitmb: int = 128,
        docbase: int = 0,
        codec=None,
        compound: bool = True,
        **kwargs,
    ) -> None: ...
    def temp_storage(self): ...
    def add_field(self, fieldname, fieldspec, **kwargs) -> None: ...
    def remove_field(self, fieldname) -> None: ...
    def has_deletions(self): ...
    def delete_document(self, docnum, delete: bool = True) -> None: ...
    def deleted_count(self): ...
    def is_deleted(self, docnum): ...
    def reader(self, reuse=None): ...
    def iter_postings(self): ...
    def add_postings_to_pool(self, reader, startdoc, docmap) -> None: ...
    def write_postings(self, lengths, items, startdoc, docmap) -> None: ...
    def write_per_doc(self, fieldnames, reader): ...
    def add_reader(self, reader) -> None: ...
    def add_document(self, **fields) -> None: ...
    def doc_count(self): ...
    def get_segment(self): ...
    def per_document_reader(self): ...
    def commit(self, mergetype=None, optimize=None, merge=None) -> None: ...
    def cancel(self) -> None: ...

class AsyncWriter(threading.Thread, IndexWriter):
    running: bool
    index: Incomplete
    writerargs: Incomplete
    delay: Incomplete
    events: Incomplete
    writer: Incomplete
    def __init__(self, index: Index, delay: float = 0.25, writerargs: dict[str, Any] | None = None) -> None: ...
    def reader(self): ...
    def searcher(self, **kwargs): ...
    def run(self) -> None: ...
    def delete_document(self, *args, **kwargs) -> None: ...
    def add_document(self, *args, **kwargs) -> None: ...
    def update_document(self, *args, **kwargs) -> None: ...
    def add_field(self, *args, **kwargs) -> None: ...
    def remove_field(self, *args, **kwargs) -> None: ...
    def delete_by_term(self, *args, **kwargs) -> None: ...
    def commit(self, *args, **kwargs) -> None: ...
    def cancel(self, *args, **kwargs) -> None: ...

def add_spelling(ix, fieldnames, commit: bool = True) -> None: ...

class BufferedWriter(IndexWriter):
    index: Incomplete
    period: Incomplete
    limit: Incomplete
    writerargs: Incomplete
    commitargs: Incomplete
    lock: Incomplete
    writer: Incomplete
    bufferedcount: int
    timer: Incomplete
    def __init__(self, index, period: int = 60, limit: int = 10, writerargs=None, commitargs=None) -> None: ...
    def __exit__(
        self, exc_type: type[BaseException] | None, exc_val: BaseException | None, exc_tb: types.TracebackType | None
    ) -> None: ...
    @property
    def schema(self): ...
    def reader(self, **kwargs): ...
    def searcher(self, **kwargs): ...
    def close(self) -> None: ...
    def commit(self, restart: bool = True) -> None: ...
    def add_reader(self, reader) -> None: ...
    def add_document(self, **fields) -> None: ...
    def update_document(self, **fields) -> None: ...
    def delete_document(self, docnum, delete: bool = True) -> None: ...
    def is_deleted(self, docnum): ...

BatchWriter = BufferedWriter
